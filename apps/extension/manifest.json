{
  "name": "JEE WALLET",
  "description": "JEE CRYPTO browser wallet for the JEE zero-fee Layer-1.",
  "version": "1.0.6",
  "manifest_version": 3,
  "minimum_chrome_version": "114",
  "browser_specific_settings": {
    "gecko": {
      "id": "jee-wallet@jeewallet.org",
      "strict_min_version": "128.0",
      "data_collection_permissions": {
        "required": ["none"]
      }
    }
  },
  "permissions": [
    "activeTab",
    "alarms",
    "downloads",
    "storage",
    "tabs"
  ],
  "background": {
    "scripts": ["background.js"],
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": [
        "content.js"
      ],
      "world": "ISOLATED",
      "run_at": "document_start"
    },
    {
      "matches": ["<all_urls>"],
      "js": [
        "content-bridge.js"
      ],
      "world": "MAIN",
      "run_at": "document_start"
    }
  ],
  "action": {
    "default_title": "JEE WALLET",
    "default_popup": "index.html",
    "default_icon": {
      "48": "icon-48.png",
      "128": "icon-128.png"
    }
  },
  "sidebar_action": {
    "default_title": "JEE WALLET",
    "default_panel": "index.html?mode=sidepanel",
    "default_icon": {
      "48": "icon-48.png",
      "128": "icon-128.png"
    }
  },
  "icons": {
    "48": "icon-48.png",
    "128": "icon-128.png"
  },
  "content_security_policy": {
    "extension_pages": "script-src 'self' 'wasm-unsafe-eval'; object-src 'self'; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com;"
  }
}
